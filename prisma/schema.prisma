generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// creating the  table  for user,doctor and appointment

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  firstName    String?
  lastName     String?
  phoneNumber  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  email        String        @unique
  appointments Appointment[]
}

model Doctor {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  firstName    String?
  lastName     String?
  phoneNumber  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  email        String        @unique
  bio          String?
  gender       Gender?
  isActive     Boolean       @default(true)
  appointments Appointment[]
}

enum Gender {
  MALE
  FEMALE
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime          @default(now())
  time      String
  duration  Int
  status    AppointmentStatus @default(PENDING)
  note      String?
  reason    String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  userId    String
  doctorId  String

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([status])
  @@index([date])
  @@index([userId])
  @@index([doctorId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
